us{transition:none;padding:0;background:0 0;border:0;box-shadow:none;opacity:1}.pswp__button:disabled{opacity:.3;cursor:auto}.pswp__icn{fill:var(--pswp-icon-color);color:var(--pswp-icon-color-secondary)}.pswp__icn{position:absolute;top:14px;left:9px;width:32px;height:32px;overflow:hidden;pointer-events:none}.pswp__icn-shadow{stroke:var(--pswp-icon-stroke-color);stroke-width:var(--pswp-icon-stroke-width);fill:none}.pswp__icn:focus{outline:0}div.pswp__img--placeholder,.pswp__img--with-bg{background:var(--pswp-placeholder-bg)}.pswp__top-bar{position:absolute;left:0;top:0;width:100%;height:60px;display:flex;flex-direction:row;justify-content:flex-end;z-index:10;pointer-events:none!important}.pswp__top-bar>*{pointer-events:auto;will-change:opacity}.pswp__button--close{margin-right:6px}.pswp__button--arrow{position:absolute;top:0;width:75px;height:100px;top:50%;margin-top:-50px}.pswp__button--arrow:disabled{display:none;cursor:default}.pswp__button--arrow .pswp__icn{top:50%;margin-top:-30px;width:60px;height:60px;background:0 0;border-radius:0}.pswp--one-slide .pswp__button--arrow{display:none}.pswp--touch .pswp__button--arrow{visibility:hidden}.pswp--has_mouse .pswp__button--arrow{visibility:visible}.pswp__button--arrow--prev{right:auto;left:0}.pswp__button--arrow--next{right:0}.pswp__button--arrow--next .pswp__icn{left:auto;right:14px;transform:scale(-1,1)}.pswp__button--zoom{display:none}.pswp--zoom-allowed .pswp__button--zoom{display:block}.pswp--zoomed-in .pswp__zoom-icn-bar-v{display:none}.pswp__preloader{position:relative;overflow:hidden;width:50px;height:60px;margin-right:auto}.pswp__preloader .pswp__icn{opacity:0;transition:opacity .2s linear;animation:pswp-clockwise 600ms linear infinite}.pswp__preloader--active .pswp__icn{opacity:.85}@keyframes pswp-clockwise{0%{transform:rotate(0)}100%{transform:rotate(360deg)}}.pswp__counter{height:30px;margin-top:15px;margin-inline-start:20px;font-size:14px;line-height:30px;color:var(--pswp-icon-color);text-shadow:1px 1px 3px var(--pswp-icon-color-secondary);opacity:.85}.pswp--one-slide .pswp__counter{display:none}.pswp__dynamic-caption{color:#fff;position:absolute;width:100%;left:0;top:0;transition:opacity 120ms linear!important}.pswp-caption-content{display:none}.pswp__dynamic-caption a{color:#fff}.pswp__dynamic-caption--faded{opacity:0!important}.pswp__dynamic-caption--aside{width:auto;max-width:300px;padding:20px 15px 20px 20px;margin-top:70px}.pswp__dynamic-caption--below{width:auto;max-width:700px;padding:15px 0 0}.pswp__dynamic-caption--on-hor-edge{padding-left:15px;padding-right:15px}.pswp__dynamic-caption--mobile{width:100%;background:rgba(0,0,0,.5);padding:10px 15px;right:0;bottom:0;top:auto!important;left:0!important}:root{--cream:#f5f0e8;--warm:#e8dcc8;--brown:#5c3d2e;--dark:#2a1a0e;--gold:#a0732a;--light:#faf7f2;--text:#3a2510;--muted:#8a7060}body{background:var(--light);color:var(--text);font-family:ff-dagny-web-pro,sans-serif;font-weight:400;font-size:18px;line-height:1.7;overflow-x:hidden}body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");pointer-events:none;z-index:1000;opacity:.4}.site-nav{position:fixed;top:0;left:0;right:0;z-index:200;background:rgba(42,26,14,.92);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid rgba(160,115,42,.2);padding:0 2rem;height:4rem;display:flex;justify-content:space-between;align-items:center}.nav-brand{font-family:eb-garamond,Georgia,serif;color:var(--gold);font-size:1.05rem;letter-spacing:.1em;text-decoration:none;display:flex;align-items:center;gap:.6rem;flex-shrink:0}.nav-brand svg{width:26px;height:26px}.nav-links{display:flex;gap:2rem;list-style:none;margin:0;padding:0}.nav-links a{color:rgba(245,240,232,.65);text-decoration:none;font-size:.78rem;letter-spacing:.2em;text-transform:uppercase;transition:color .25s;font-family:ff-dagny-web-pro,sans-serif;white-space:nowrap}.nav-links a:hover{color:var(--gold)}.nav-cta{display:inline-block;background:var(--gold);color:var(--dark);padding:.5rem 1.25rem;font-family:ff-dagny-web-pro,sans-serif;font-size:.78rem;font-weight:500;letter-spacing:.15em;text-transform:uppercase;text-decoration:none;transition:background .25s,transform .2s;white-space:nowrap;flex-shrink:0}.nav-cta:hover{background:#c4922e;transform:translateY(-1px)}.site-hero{position:relative;min-height:100vh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:4rem 2rem;background:var(--dark);overflow:hidden}.site-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 30% 40%,rgba(92,61,46,.5) 0%,transparent 70%),radial-gradient(ellipse 60% 80% at 70% 60%,rgba(160,115,42,.2) 0%,transparent 60%);pointer-events:none}.site-hero::after{content:'';position:absolute;width:600px;height:600px;border-radius:50%;border:1px solid rgba(160,115,42,.15);box-shadow:0 0 0 40px rgba(160,115,42,5%),0 0 0 80px rgba(160,115,42,4%),0 0 0 120px rgba(160,115,42,3%),0 0 0 160px rgba(160,115,42,2%);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none}.hero-content{position:relative;z-index:1;animation:fadeUp 1.2s ease forwards}.hero-logo-mark{font-family:eb-garamond,Georgia,serif;font-size:3rem;color:var(--gold);margin-bottom:1rem;opacity:.85;display:block}.hero-headline{font-family:eb-garamond,Georgia,serif;font-size:clamp(3rem,8vw,7rem);font-weight:700;color:var(--cream);line-height:1.05;letter-spacing:-.02em;margin:0 0 .3em}.hero-headline span{color:var(--gold);font-style:italic}.hero-tagline{font-size:clamp(.85rem,2vw,1rem);color:rgba(245,240,232,.5);letter-spacing:.25em;text-transform:uppercase;margin:1.5rem 0 0}.hero-scroll-hint{position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:.5rem;color:rgba(245,240,232,.25);font-size:.7rem;letter-spacing:.3em;text-transform:uppercase;animation:bounce 2s infinite;z-index:1}.hero-scroll-hint::after{content:'↓';font-size:1.1rem}.home-section{padding:6rem 2rem}.home-section--light{background:var(--light)}.home-section--cream{background:var(--cream)}.home-section--dark{background:var(--dark)}.home-section-inner{max-width:900px;margin:0 auto}.home-section-inner--center{text-align:center}.home-divider{width:100%;height:1px;background:linear-gradient(to right,transparent,var(--warm),transparent)}.section-label{font-family:ff-dagny-web-pro,sans-serif;font-size:.7rem;letter-spacing:.4em;text-transform:uppercase;color:var(--gold);margin-bottom:1.5rem;display:flex;align-items:center;gap:1rem}.section-label::after{content:'';flex:1;max-width:60px;height:1px;background:var(--gold);opacity:.35}.section-label--light{color:var(--gold);justify-content:center}.section-label--light::after{display:none}h2{font-family:eb-garamond,Georgia,serif;font-size:clamp(2rem,5vw,3.2rem);font-weight:400;line-height:1.2;color:var(--dark);margin:0 0 1.5rem}h2 em{color:var(--gold);font-style:italic}.h2--light{color:var(--cream)}.h2--light em{color:var(--gold)}.prose-text p{color:var(--muted);margin-bottom:1.2rem;font-size:1.05rem}.leistungen-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:2rem;margin-top:3rem}.leistung-card{background:var(--light);border:1px solid var(--warm);padding:2rem;position:relative;transition:transform .3s,box-shadow .3s}.leistung-card:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(92,61,46,.1)}.leistung-card::before{content:attr(data-nr);position:absolute;top:1.2rem;right:1.5rem;font-family:eb-garamond,Georgia,serif;font-size:2.5rem;color:var(--warm);font-weight:700;line-height:1}.leistung-card h3{font-family:eb-garamond,Georgia,serif;font-size:1.3rem;color:var(--brown);margin:0 0 .8rem}.leistung-card p{font-size:.95rem;color:var(--muted);margin:0}.anfrage-text{color:rgba(245,240,232,.6);max-width:540px;margin:0 auto 2.5rem;font-size:1.05rem}.anfrage-btn{display:inline-block;background:var(--gold);color:var(--dark);padding:1rem 2.5rem;font-family:ff-dagny-web-pro,sans-serif;font-size:.9rem;font-weight:500;letter-spacing:.15em;text-transform:uppercase;text-decoration:none;transition:background .25s,transform .2s}.anfrage-btn:hover{background:#c4922e;transform:translateY(-2px)}#galerie .home-section-inner{margin-bottom:3rem}@keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}@keyframes bounce{0%,100%{transform:translateX(-50%)translateY(0)}50%{transform:translateX(-50%)translateY(8px)}}@media(max-width:640px){.nav-links{display:none}.home-section{padding:4rem 1.5rem}.leistungen-grid{grid-template-columns:1fr}}.lazyload,.lazyloading{opacity:0}.lazyloaded{opacity:1;transition:opacity 300ms}img.lazyload:not([src]){visibility:hidden}